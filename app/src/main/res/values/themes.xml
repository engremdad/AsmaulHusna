<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AsmaulHusna" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/mushaf_page</item>
        <item name="android:statusBarColor">@color/mushaf_page</item>
        <item name="android:navigationBarColor">@color/mushaf_page</item>
        <item name="android:colorPrimary">@color/mushaf_page</item>
        <item name="android:colorAccent">@color/mushaf_gold</item>
    </style>

    <!-- Android 12+ splash: gold Mushaf mark on the deep-emerald page, then hands
         off to the main theme. Applied as the launch theme in the manifest. -->
    <style name="Theme.AsmaulHusna.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/mushaf_page</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AsmaulHusna</item>
    </style>
</resources>