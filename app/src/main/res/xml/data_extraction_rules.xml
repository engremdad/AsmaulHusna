<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup/transfer scope (Android 12+). Allowlist: only the user's own
   preferences (favorites, per-name zikir counts, language, display and
   reminder settings) are backed up / transferred. Anything not listed —
   including the FCM/Firebase id files — is excluded automatically, so a
   restored install re-registers cleanly.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="favorites.xml" />
        <include domain="sharedpref" path="zikir.xml" />
        <include domain="sharedpref" path="settings.xml" />
        <include domain="sharedpref" path="reminders.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="favorites.xml" />
        <include domain="sharedpref" path="zikir.xml" />
        <include domain="sharedpref" path="settings.xml" />
        <include domain="sharedpref" path="reminders.xml" />
    </device-transfer>
</data-extraction-rules>
